```env
# Copy this file to backend/.env for local development.
# Never commit real .env files or production secrets.

# --- Backend server ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# --- Security ---
# Generate a strong value with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Initial admin account.
# Used only when the database has no admin user yet.
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me-before-first-run

# Comma-separated list of allowed browser origins.
CORS_ORIGINS=http://localhost:5173, http://127.0.0.1:5173

# Maximum upload size in bytes.
MAX_UPLOAD_BYTES=5242880

# --- Database ---
# Defaults to backend/portfolio.db when unset.
DATABASE_URL=sqlite:///./portfolio.db

# --- Frontend ---
VITE_API_BASE_URL=/api
```
